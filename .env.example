# Пароль для доступа к приложению (измените на свой!)
APP_PASSWORD=your-secure-password-here

# Секретный ключ для сессий (минимум 32 символа)
SESSION_SECRET=generate-a-random-secret-at-least-32-chars

# База данных SQLite
DATABASE_URL=file:./dev.db

# URL TTS сервиса
TTS_SERVICE_URL=http://localhost:3031

# Telegram Bot Token (опционально)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (опционально)
TELEGRAM_CHAT_ID=
